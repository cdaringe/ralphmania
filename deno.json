{
  "name": "@cdaringe/ralphmania",
  "version": "0.42.0",
  "license": "MIT",
  "exports": "./mod.ts",
  "lint": {
    "exclude": ["src/set-fns.ts"],
    "rules": {
      "tags": ["recommended"],
      "include": [
        "ban-untagged-todo",
        "default-param-last",
        "eqeqeq",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "guard-for-in",
        "no-eval",
        "no-implicit-declare-namespace-export",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-self-compare",
        "no-slow-types",
        "no-sparse-arrays",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-undef",
        "single-var-declarator",
        "triple-slash-reference",
        "verbatim-module-syntax"
      ]
    }
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-run --allow-env --allow-net",
    "test:coverage": "deno test --allow-read --allow-write --allow-run --allow-env --allow-net --clean --coverage=coverage/ && deno coverage coverage/",
    "test:coverage:html": "deno test --allow-read --allow-write --allow-run --allow-env --allow-net --clean --coverage=coverage/ && deno coverage --html coverage/",
    "test:coverage:enforce": "deno test --allow-read --allow-write --allow-run --allow-env --allow-net --clean --coverage=coverage/ && bash -c 'deno coverage coverage/ 2>&1 | deno run --allow-read scripts/check-coverage.ts'",
    "fmt": "deno fmt",
    "check": "deno check mod.ts",
    "ralph": "deno run -A mod.ts --iterations 30 --agent claude --plugin plugin.ralph.ts",
    "ralph:debug": "deno run --inspect-brk -A mod.ts --iterations 30 --agent claude --plugin plugin.ralph.ts",
    "yeet": "deno fmt || true && deno task test:coverage && git add . || true && git commit -m 'chore: bump version' || true && gph || true && deno publish"
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "neverthrow": "npm:neverthrow@^8.2.0"
  }
}
